# Invoxia AI local/private AI services
#
# Copy to .env.ai or merge into your deployment environment.
# Do not expose Ollama or Whisper ports publicly.

OLLAMA_MODEL=qwen3:14b
WHISPER_MODEL=large-v3-turbo-q5_0
WHISPER_PORT=9000
OLLAMA_PORT=11434

# For weak local machines, use:
# OLLAMA_MODEL=qwen3:4b
# WHISPER_MODEL=base
#
# For premium GPU-backed installs, use:
# OLLAMA_MODEL=qwen3:30b
# WHISPER_MODEL=large-v3-turbo
